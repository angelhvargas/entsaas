# ─────────────────────────────────────────────────────────────────────────────
# EntSaaS — Environment Configuration Template
# Copy this file to .env and fill in the values.
# All optional variables are commented out with their defaults or example values.
# Variables marked REQUIRED must be set; the server will panic at startup if missing.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application Security & Global ─────────────────────────────────────────────
# REQUIRED: 64-character hex string (32 random bytes). Generate with: openssl rand -hex 32
# Used to sign all JWTs. Must be at least 32 characters. No default — server panics if unset.
JWT_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS

# REQUIRED: 64-character hex string (32 random bytes). Generate with: openssl rand -hex 32
# Used for encrypting secrets using AES-256-GCM.
ENTSAAS_MASTER_KEY=REPLACE_WITH_64_HEX_CHARS

# Master key version for rotation coordination.
# ENTSAAS_MASTER_KEY_VERSION=1

# ── Databases & Cache ─────────────────────────────────────────────────────────
# REQUIRED: Postgres connection string. Server panics if unset.
DATABASE_URL=postgres://entsaas:secret-db-password@localhost:5432/entsaas?sslmode=disable

# Per-plane connection pool tuning (optional).
# Zero / unset = use package defaults (MaxConns=25, MinConns=5).
# DB_MAX_CONNS=25
# DB_MIN_CONNS=5

# Redis (optional — for session cache, rate limiting, eventing broker)
# REDIS_URL=redis://localhost:6379/0

# ── Server & Dev Mode ─────────────────────────────────────────────────────────
# PORT=8080
# GIN_MODE=release
# LOG_LEVEL=info

# 1 = disable asset caching for SPA fallback handler; 0 = production
# ENTSAAS_DEV=0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Default covers Vite dev server on both localhost and 127.0.0.1.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# ── Session Lifetimes ─────────────────────────────────────────────────────────
# Access token is a short-lived JWT; refresh token is a long-lived rotated cookie.
# Values use Go duration format (e.g. 15m, 1h, 720h).
# ENTSAAS_ACCESS_TOKEN_TTL=15m
# ENTSAAS_REFRESH_TOKEN_TTL=720h

# Base URL for email links (password reset, invites, etc.)
# ENTSAAS_BASE_URL=http://localhost:5173
# PUBLIC_APP_BASE_URL=http://localhost:5173

# ── Email System ──────────────────────────────────────────────────────────────
# Sender implementation ('log' for dev, 'smtp' for prod)
# MAIL_SENDER=log

# SMTP Relay Configuration (Required if MAIL_SENDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=EntSaaS

# ── AI Integration ────────────────────────────────────────────────────────────
# AI provider configuration. Supports OpenAI-compatible APIs.
# AI_ENABLED=false
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
# AI_API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o
# AI_MAX_TOKENS=4096
# AI_TEMPERATURE=0.7

# ── Eventing Pipeline ─────────────────────────────────────────────────────────
# Enable the outbox relayer (Postgres outbox → Redis stream)
# OUTBOX_RELAYER_ENABLED=false

# Enable channel dispatchers for actual delivery
# DISPATCHERS_ENABLED=false

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Self-service registration. Set to true to enable POST /v1/auth/register.
FF_REGISTRATION_ENABLED=true

# Email verification. When true, new users must verify email before accessing resources.
# FF_EMAIL_VERIFICATION_ENABLED=false
